{
  "name": "gloam-claude-design",
  "version": "0.2.0",
  "private": true,
  "description": "Gloam — a dark theme for the Claude Design native panels.",
  "homepage": "https://github.com/justskiv/gloam-claude-design",
  "author": "Nikolay Tuzov",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "start": "web-ext run",
    "lint": "npm run lint:firefox && npm run lint:chromium && eslint . && stylelint \"**/*.css\" && prettier --check .",
    "lint:firefox": "web-ext lint",
    "lint:chromium": "npm run build:chromium-source && node scripts/lint-chromium.js",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "test": "node --test test/*.test.js",
    "coverage": "c8 node --test test/*.test.js",
    "build:chromium-source": "node scripts/build-chromium.js",
    "run:chromium": "npm run build:chromium-source && web-ext run --source-dir=dist/chromium --target=chromium",
    "build": "web-ext build",
    "build:chromium": "npm run build:chromium-source && web-ext build --source-dir=dist/chromium --artifacts-dir=web-ext-artifacts/chromium --overwrite-dest",
    "build:all": "npm run build && npm run build:chromium",
    "sign": "web-ext sign --channel=unlisted"
  },
  "webExt": {
    "build": {
      "overwriteDest": true
    },
    "ignoreFiles": [
      "README.md",
      "AGENTS.md",
      "amo-metadata.json",
      "assets",
      "assets/**",
      "icons/icon.svg",
      "test",
      "test/**",
      "coverage",
      "coverage/**",
      "dist",
      "dist/**",
      "package.json",
      "package-lock.json",
      "Taskfile.yml",
      "eslint.config.js",
      "scripts",
      "scripts/**",
      "codecov.yml",
      "CHANGELOG.md"
    ]
  },
  "c8": {
    "include": [
      "color.js"
    ],
    "reporter": [
      "text",
      "lcovonly"
    ],
    "report-dir": "coverage"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "web-ext": "^8.3.0"
  }
}
